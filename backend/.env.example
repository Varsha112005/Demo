PORT=5000
NODE_ENV=development

# MongoDB is required. Encode special characters in your password before adding it to the URI.
# Example: my@pass#123 becomes my%40pass%23123
MONGO_URI=mongodb+srv://username:encodedPassword@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_URI_DIRECT=your_direct_mongodb_connection_string

# Cloudinary is optional at startup, but required for upload features.
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

FRONTEND_URL=http://localhost:5173
APP_NAME=Auth Demo App

JWT_SECRET=your_strong_jwt_secret_key
JWT_EXPIRES_IN=7d

# SMTP is optional at startup. If missing, the backend still starts and OTP APIs return 503.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_digit_gmail_app_password_without_spaces
SMTP_FROM=Auth App <your_email@gmail.com>

OTP_EXPIRES_IN_MINUTES=10

# Render backend settings:
# Root Directory: backend
# Build Command: npm install
# Start Command: npm start
